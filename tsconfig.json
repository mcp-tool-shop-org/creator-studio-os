{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@creator-studio-os/core": ["./packages/core/src/index.ts"],
      "@creator-studio-os/fcp": ["./packages/fcp/src/index.ts"],
      "@creator-studio-os/compressor": ["./packages/compressor/src/index.ts"],
      "@creator-studio-os/motion": ["./packages/motion/src/index.ts"],
      "@creator-studio-os/pixelmator": ["./packages/pixelmator/src/index.ts"],
      "@creator-studio-os/logic": ["./packages/logic/src/index.ts"],
      "@creator-studio-os/keynote": ["./packages/keynote/src/index.ts"],
      "@creator-studio-os/iwork-docs": ["./packages/iwork-docs/src/index.ts"],
      "@creator-studio-os/protocols": ["./packages/protocols/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "apps/*/src/**/*"
  ],
  "exclude": ["node_modules", "packages/*/dist", "apps/*/dist", "tests"]
}
