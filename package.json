{
  "name": "@mcptoolshop/creator-studio-os",
  "version": "1.6.4",
  "description": "MCP control plane for Apple Creator Studio apps. FCPXML-driven timeline authoring with canonical project directories.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "final-cut-pro",
    "fcpxml",
    "applescript",
    "video-editing",
    "creator-studio",
    "compressor",
    "logic-pro",
    "automation"
  ],
  "license": "MIT",
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "homepage": "https://github.com/mcp-tool-shop-org/creator-studio-os",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-tool-shop-org/creator-studio-os.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/creator-studio-os/issues"
  },
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "creator-studio-os": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "node dist/cli.js verify",
    "smoke": "node dist/cli.js smoke",
    "smoke:ci": "node dist/cli.js smoke --ci",
    "smoke:dry": "node dist/cli.js smoke --dry-run",
    "smoke:fixtures": "bash tests/fixtures/make-fixtures.sh",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.7.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
