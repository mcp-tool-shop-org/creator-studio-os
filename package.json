{
  "name": "creator-studio-os-workspace",
  "version": "2.0.1",
  "private": true,
  "description": "Workspace root — npm workspaces for @creator-studio-os/* packages",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace=@creator-studio-os/core && npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "node apps/creator-studio-os/dist/cli.js verify",
    "smoke": "node apps/creator-studio-os/dist/cli.js smoke",
    "smoke:ci": "node apps/creator-studio-os/dist/cli.js smoke --ci",
    "smoke:dry": "node apps/creator-studio-os/dist/cli.js smoke --dry-run",
    "smoke:fixtures": "bash tests/fixtures/make-fixtures.sh"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
